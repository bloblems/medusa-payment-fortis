{
  "name": "medusa-payment-fortis",
  "version": "0.1.2",
  "description": "Fortis payment provider for MedusaJS 2.x",
  "author": "Bloblems",
  "license": "MIT",
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-payment",
    "fortis",
    "payment-provider",
    "ecommerce"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./storefront": {
      "types": "./dist/storefront/index.d.ts",
      "default": "./dist/storefront/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "smoke": "node scripts/smoke-test.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.12.0",
    "@medusajs/medusa": "^2.12.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@medusajs/framework": "^2.12.0",
    "@medusajs/medusa": "^2.12.0",
    "@medusajs/types": "^2.12.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
