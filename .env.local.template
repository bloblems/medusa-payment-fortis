# Fortis sandbox credentials — fill in from your Fortis developer portal.
# Copy this file to .env.local and never commit the filled-in version.

# Per-merchant credentials (sent as request headers)
FORTIS_USER_ID=
FORTIS_USER_API_KEY=

# Hardcoded per-integration ID — same value across all merchants who install this plugin
FORTIS_DEVELOPER_ID=

# HMAC secret used to sign PayForm/AccountForm iframe URLs
FORTIS_USER_HASH_KEY=

# Default merchant location for transactions
FORTIS_LOCATION_ID=

# Sandbox: https://api.sandbox.zeamster.com
# Production: https://api.zeamster.com
# Note: api.fortis.tech is the developer portal, NOT the API host.
FORTIS_API_BASE_URL=https://api.sandbox.zeamster.com

# Required: Product Transaction Id for the CC service (Fortis portal: Services tab → CC service)
FORTIS_CC_PRODUCT_TRANSACTION_ID=

# Optional: Product Transaction Id for the ACH service (for future ACH support)
# FORTIS_ACH_PRODUCT_TRANSACTION_ID=

# Optional: capture funds immediately on authorization.
# - "false" (default) → authonly. Reserve funds; capture later via the order admin or workflow.
# - "true"            → sale. Auth + capture in one shot. Money moves on order placement.
# FORTIS_CAPTURE=false
